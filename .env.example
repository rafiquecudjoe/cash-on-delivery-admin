NEXT_PUBLIC_API_URL=http://localhost:3000
# MinIO origin (no bucket suffix) — used for CSP connect-src so browser uploads
# can PUT to presigned URLs, and for Next image remotePatterns.
NEXT_PUBLIC_MINIO_URL=https://minio.example.com
# Public site origin — used to build per-product ad URLs (`/p/<slug>`)
# shown to admins for copying into FB/IG/TikTok ads.
NEXT_PUBLIC_SITE_URL=https://cashondeliverygh.com
NODE_ENV=development
